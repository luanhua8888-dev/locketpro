{
  "expo": {
    "name": "Luna Snap",
    "slug": "locket-clone",
    "scheme": "locketclone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo1_nobg.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091B42",
        "foregroundImage": "./assets/logo1_nobg.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo1_nobg.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
