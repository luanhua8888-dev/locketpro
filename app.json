{
  "expo": {
    "name": "Luna Snap",
    "slug": "locket-clone",
    "scheme": "locketclone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo1_nobg.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lunasnap.app"
    },
    "android": {
      "package": "com.lunasnap.app",
      "adaptiveIcon": {
        "backgroundColor": "#091B42",
        "foregroundImage": "./assets/logo1_nobg.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo1_nobg.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      "expo-video",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "2866136e-8dd9-4f41-bb06-b2973b72e6f7"
      }
    },
    "owner": "amtluan"
  }
}
